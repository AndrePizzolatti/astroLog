# Copy this file to .env and fill in your values

DATABASE_URL="postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://[REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="[openssl rand -base64 32]"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

NASA_API_KEY="DEMO_KEY"

# Alertas por e-mail (Resend) + cron diário
# Free tier: o remetente onboarding@resend.dev só entrega para o e-mail dono da conta Resend.
# Para enviar a qualquer destinatário, verifique um domínio e troque o EMAIL_FROM.
RESEND_API_KEY=""
EMAIL_FROM="AstroLog <onboarding@resend.dev>"
# Segredo que protege /api/cron/alerts. A Vercel injeta este header no cron automaticamente.
CRON_SECRET="[openssl rand -base64 32]"
